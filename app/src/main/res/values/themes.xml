<resources xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android">
    <style name="Theme.BTL_DNC" parent="Theme.MaterialComponents.Light.NoActionBar">
    </style>

    <style name="Theme.BTL_DĐNC" parent="Base.Theme.BTL_DĐNC" />
    <style name="RoundedSquareShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="CircleShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="CustomBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
    <style name="Widget.CustomChip.Filter" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">#000000</item>
        <item name="chipBackgroundColor">@android:color/white</item>
        <item name="chipStrokeColor">@drawable/color_chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">24dp</item>

        <item name="checkedIconEnabled">false</item>
    </style>
</resources>