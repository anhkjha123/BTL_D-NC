<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:padding="@dimen/space_24">

    <LinearLayout
        android:id="@+id/layoutStepIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/step1"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_step_active"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/app_on_primary"
            android:textStyle="bold" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/app_outline" />

        <TextView
            android:id="@+id/step2"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_step_inactive"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/app_primary"
            android:textStyle="bold" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/app_outline" />

        <TextView
            android:id="@+id/step3"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_step_inactive"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/app_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:layout_constraintBottom_toTopOf="@+id/btnNext"
        app:layout_constraintTop_toBottomOf="@id/layoutStepIndicator">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ và tên"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Xem xét lại tài khoản và tên người thông báo"
                android:textColor="@color/text_secondary" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_input_gray"
                android:paddingHorizontal="16dp">
                <ImageView
                    android:id="@+id/ic_user"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_user" />
                <EditText
                    android:id="@+id/edtAuthorName"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toRightOf="@id/ic_user"
                    android:background="@android:color/transparent"
                    android:layout_marginStart="12dp"
                    android:hint="Họ và tên"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_gray"
                android:paddingHorizontal="16dp">
                <ImageView
                    android:id="@+id/ic_mail"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_mail" />
                <EditText
                    android:id="@+id/edtAuthorEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toRightOf="@id/ic_mail"
                    android:background="@android:color/transparent"
                    android:layout_marginStart="12dp"
                    android:hint="Email"
                    android:enabled="false"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />
            </RelativeLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tạo nội dung thông báo"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Điền nội dung bạn muốn thông báo tại đây"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/edtTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/bg_input_gray"
                android:hint="Điền tiêu đề tại đây"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edtContent"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:hint="Viết thông báo của bạn tại đây"
                android:padding="20dp"
                android:textColorHint="@color/app_primary"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn ảnh thumbnail"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chọn ảnh thumbnail"
                android:textColor="@color/text_secondary" />

            <LinearLayout
                android:id="@+id/btnSelectImage"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/ic_folder"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_folder" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Chọn ảnh thumbnail"
                    android:textColor="@color/app_primary"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ViewFlipper>

    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:text="Lưu &amp; Tiếp tục"
        android:textSize="16sp"
        style="@style/Widget.App.Button.Primary"
        app:layout_constraintBottom_toTopOf="@+id/btnBack" />

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:padding="10dp"
        android:text="Back"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>